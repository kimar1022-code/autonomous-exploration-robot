<?xml version="1.0" ?>
<robot name="autonomous_robot">
  
  <!-- ===== Base Link (로봇 본체: 162×212×140mm) ===== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.162 0.212 0.140"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <!-- ===== Left Wheel (바퀴 반지름 32.5mm) ===== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Left Wheel Joint: 좌우 간격 162mm, 중심 기준 81mm -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="-0.081 0.106 -0.032"/>
  </joint>

  <!-- ===== Right Wheel ===== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0.081 0.106 -0.032"/>
  </joint>

  <!-- ===== IMU Link (Arduino Nano 33 BLE Sense) ===== -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.07"/>
  </joint>

  <!-- ===== Camera Link (파이캠 V2) ===== -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.081 -0.106 -0.05"/>
  </joint>

  <!-- ===== LiDAR (RPLIDAR A1M8-R6, 3층) =====
       rplidar 노드가 /scan 을 frame_id="laser" 로 발행하므로 프레임 이름을 laser 로 통일.
       TF 체인: base_link → laser (robot_state_publisher 가 이 fixed joint 로 발행)
       ⚠️ origin 은 실측 필요 — 라이다 회전중심의 base_link 기준 오프셋(m): X=전방+, Y=좌측+, Z=상방+.
          Z=0.10 은 3층 높이 임시값. 맵이 90/180도 틀어지면 rpy 의 yaw(마지막 값)로 보정. -->
  <link name="laser"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <!-- odom 프레임은 URDF에 두지 않는다.
       odom → base_link 변환은 base_controller.py 가 엔코더 적분값으로 동적 TF 발행하고,
       map → odom 은 slam_toolbox 가 발행한다. -->

</robot>
