<?xml version="1.0" ?>
<robot name="autonomous_robot">
  
  <!-- ===== Base Link (로봇 본체: 162×212×140mm) ===== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.162 0.212 0.140"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <!-- ===== Left Wheel (바퀴 반지름 32.5mm) ===== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Left Wheel Joint: 좌우 간격 162mm, 중심 기준 81mm -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="-0.081 0.106 -0.032"/>
  </joint>

  <!-- ===== Right Wheel ===== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0.081 0.106 -0.032"/>
  </joint>

  <!-- ===== IMU Link (Arduino Nano 33 BLE Sense) ===== -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.07"/>
  </joint>

  <!-- ===== Camera Link (파이캠 V2) ===== -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.081 -0.106 -0.05"/>
  </joint>

  <!-- ===== LiDAR Link (RPLIDAR A1M8-R6, 3층) ===== -->
  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.10"/>
  </joint>

  <!-- ===== Odometry Frame ===== -->
  <link name="odom"/>
  <joint name="odom_base_joint" type="floating">
    <parent link="odom"/>
    <child link="base_link"/>
  </joint>

</robot>
